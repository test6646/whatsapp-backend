# Port for the server (Railway sets this automatically via $PORT)
PORT=3001

# Frontend URL for CORS - Railway deployment handles CORS with "*" 
# But you can specify your actual domain for production security
FRONTEND_URL=https://preview--test-joy-zone.lovable.app

# Optional: Webhook URL for notifications
WEBHOOK_URL=

# Optional: Admin phone numbers (comma separated)
ADMIN_PHONES=+919106403233,+91902347039,+919408073784
